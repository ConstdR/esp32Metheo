# Defaults for Weather Station
# Wi-Fi credentials are now configured via AP mode (captive portal).
# On first boot, the device creates an open AP "Metheo_XXXXXX".
# Connect to it and open http://192.168.4.1 to enter Wi-Fi credentials.

CONFIG_SLEEP_MINUTES=15
CONFIG_LED_GPIO=5
CONFIG_AP_TIMEOUT_SEC=300
CONFIG_WIFI_FAIL_THRESHOLD=5
